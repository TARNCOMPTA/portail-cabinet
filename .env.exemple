# Configuration du portail pour TON cabinet — copie ce fichier en « .env »
# à côté de docker-compose.yml puis adapte les valeurs.
# (le script installation/install.sh le génère automatiquement)

# Nom de domaine du portail (l'enregistrement DNS A doit pointer vers le VPS)
DOMAIN=portail.moncabinet.fr

# URL publique complète (utilisée par le connecteur Claude/MCP — garde https://)
PUBLIC_URL=https://portail.moncabinet.fr

# E-mail utilisé pour le certificat HTTPS Let's Encrypt (avis d'expiration)
ACME_EMAIL=contact@moncabinet.fr
