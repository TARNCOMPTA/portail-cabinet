# Fins de ligne déterministes : LF partout dans le dépôt (indispensable côté Linux/Docker),
# CRLF uniquement pour les scripts Windows .bat.
* text=auto eol=lf
*.bat text eol=crlf

# Fichiers exclus de l'archive de mise à jour en ligne (git archive, cf scripts/publier-maj.mjs).
update export-ignore
.gitattributes export-ignore
.git-blame-ignore-revs export-ignore
.prettierignore export-ignore
.prettierrc.json export-ignore
eslint.config.js export-ignore
test export-ignore
installation export-ignore
# scripts/ : seul l'outil de publication (poste de dev) est exclu — les scripts de
# MAINTENANCE doivent arriver sur les instances (VPS/Docker) via la maj en ligne.
# NB : exclure le DOSSIER scripts empecherait git archive d'evaluer toute exception.
scripts/publier-maj.mjs export-ignore
